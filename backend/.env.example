# ───────────────────────────────────────────────────────────────
# INSPECTA BUILDOS — Backend environment
# Copy to ".env" and adjust. `npm start` uses LOCAL Postgres below;
# `docker compose up` overrides DATABASE_URL to the bundled db service.
# ───────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Frontend origin allowed by CORS (Vite dev server)
CORS_ORIGIN=http://localhost:3000

# ── Database (LOCAL Postgres for `npm start`) ──────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inspecta_buildos?schema=public

# ── Auth ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-please-rotate-in-prod
JWT_REFRESH_SECRET=change-me-refresh-secret-please-rotate-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── AI provider abstraction ────────────────────────────────────
# Default provider when none specified. One of: openrouter | claude | gemini
AI_PROVIDER=openrouter

# OpenRouter (default, free models). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Document storage (Module 7, optional) ─────────────────────
# When set, /api/documents/upload-url returns Supabase signed upload URLs.
# Leave blank to register external file URLs manually instead.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=documents

# Seed admin (created by `npm run seed`)
SEED_ADMIN_EMAIL=admin@inspecta.ai
SEED_ADMIN_PASSWORD=Admin@12345
