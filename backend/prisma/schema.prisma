// INSPECTA BUILDOS — Prisma schema
// Multi-tenant construction ERP. All business records are scoped by
// organizationId; project-level records also carry projectId for fast scoping.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the musl target is for the Alpine Docker image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  SYSTEM_ADMIN
  PROJECT_MANAGER
  SITE_ENGINEER
  QUANTITY_SURVEYOR
  STOREKEEPER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectHealth {
  OPTIMAL
  WARNING
  CRITICAL
}

enum ContractType {
  LUMP_SUM
  UNIT_PRICE
  COST_PLUS
  TIME_AND_MATERIAL
}

enum ContractStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
}

enum CostCategory {
  LABOR
  MATERIAL
  EQUIPMENT
  SUBCONTRACTOR
  OVERHEAD
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  REJECTED
}

enum MovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NcrStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum InspectionResult {
  PASS
  FAIL
  PENDING
}

enum IncidentType {
  NEAR_MISS
  FIRST_AID
  MEDICAL
  LOST_TIME
  FATALITY
  PROPERTY_DAMAGE
}

enum RiskStatus {
  OPEN
  MITIGATING
  CLOSED
}

enum PoStatus {
  DRAFT
  ISSUED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum NotificationType {
  DELAY
  COST_OVERRUN
  LOW_STOCK
  SAFETY_INCIDENT
  NCR
  GENERAL
  APPROVAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ────────────────────────── Tenancy ──────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Company settings (managed by SYSTEM_ADMIN via /api/organization)
  legalName String?
  industry  String?
  country   String?
  timezone  String?
  currency  String?
  phone     String?
  address   String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  clients       Client[]
  projects      Project[]
  contracts     Contract[]
  auditLogs     AuditLog[]
  materials     Material[]
  suppliers     Supplier[]
  documents     Document[]
  notifications Notification[]

  @@map("organizations")
}

// ──────────────────────────── Users ──────────────────────────

model User {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  passwordHash   String
  fullName       String
  role           Role      @default(SITE_ENGINEER)
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens   RefreshToken[]
  managedProjects Project[]      @relation("ProjectManager")
  auditLogs       AuditLog[]
  notifications   Notification[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────── Clients & Contracts ─────────────────

model Client {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  taxNumber      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]
  contracts    Contract[]

  @@index([organizationId])
  @@map("clients")
}

model Contract {
  id             String         @id @default(cuid())
  organizationId String
  clientId       String
  projectId      String?        @unique
  reference      String
  contractNumber String?
  type           ContractType   @default(LUMP_SUM)
  status         ContractStatus @default(DRAFT)
  value          Decimal        @default(0) @db.Decimal(18, 2)
  currency       String         @default("USD")
  startDate      DateTime?
  endDate        DateTime?
  contractDate         DateTime?
  commencementDate     DateTime?
  defectsLiabilityDays Int?
  retentionPct         Decimal?  @db.Decimal(5, 2)
  advancePayment       Decimal?  @db.Decimal(18, 2)
  documentsUrl         String?
  // Lifecycle / audit columns (multi-tenant spec)
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("contracts")
}

// ─────────────────────────── Projects ────────────────────────

model Project {
  id             String        @id @default(cuid())
  organizationId String
  clientId       String?
  managerId      String?
  code           String
  name           String
  description    String?
  location       String?
  projectType         String?
  category            String?
  timezone            String?
  gpsLat              Float?
  gpsLng              Float?
  plannedProfitMargin Decimal?      @db.Decimal(5, 2)
  status         ProjectStatus @default(PLANNING)
  health         ProjectHealth @default(OPTIMAL)
  budget         Decimal       @default(0) @db.Decimal(18, 2)
  currency       String        @default("USD")
  progressPct    Float         @default(0)
  startDate      DateTime?
  endDate        DateTime?
  actualEndDate  DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  manager      User?        @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)
  contract     Contract?

  wbsItems         WbsItem[]
  boqItems         BoqItem[]
  productionEntries ProductionEntry[]
  budgetLines      BudgetLine[]
  costEntries      CostEntry[]
  invoices         Invoice[]
  payments         Payment[]
  stockMovements   StockMovement[]
  purchaseOrders   PurchaseOrder[]
  inspections      Inspection[]
  ncrs             Ncr[]
  incidents        Incident[]
  toolboxTalks      ToolboxTalk[]
  risks             Risk[]
  documents         Document[]
  scheduleActivities ScheduleActivity[]
  siteDiaries        SiteDiary[]
  fieldTasks         FieldTask[]
  attendances        Attendance[]
  approvalRequests   ApprovalRequest[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([clientId])
  @@map("projects")
}

// ───────────────────────── Audit trail ───────────────────────

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  userId         String?
  action         AuditAction
  entity         String
  entityId       String?
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, entity])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ──────────────────── M1 — Planning: WBS / BOQ ───────────────

model WbsItem {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  parentId       String?
  code           String
  name           String
  description    String?
  unit           String?
  quantity       Decimal? @db.Decimal(18, 3)
  level          Int      @default(1)
  weightPct      Float    @default(0)
  progressPct    Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   WbsItem?  @relation("WbsTree", fields: [parentId], references: [id], onDelete: SetNull)
  children WbsItem[] @relation("WbsTree")
  boqItems BoqItem[]

  @@index([organizationId])
  @@index([projectId])
  @@map("wbs_items")
}

model BoqItem {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  wbsItemId      String?
  code           String
  category       String?
  description    String
  unit           String   @default("unit")
  quantity       Decimal  @default(0) @db.Decimal(18, 3)
  rate           Decimal  @default(0) @db.Decimal(18, 2)
  amount         Decimal  @default(0) @db.Decimal(18, 2)
  markupPct      Decimal? @db.Decimal(5, 2)
  contingencyPct Decimal? @db.Decimal(5, 2)
  budget         Decimal  @default(0) @db.Decimal(18, 2)
  revision       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsItem WbsItem? @relation(fields: [wbsItemId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@map("boq_items")
}

// ──────────────────── M2 — Production Control ────────────────

model ProductionEntry {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  date            DateTime @default(now())
  wbsActivity     String
  unit            String   @default("unit")
  plannedQty      Decimal  @default(0) @db.Decimal(18, 3)
  actualQty       Decimal  @default(0) @db.Decimal(18, 3)
  laborHours      Decimal  @default(0) @db.Decimal(12, 2)
  equipmentHours  Decimal  @default(0) @db.Decimal(12, 2)
  weatherCondition String?
  remarks         String?
  photos          String[]
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, date])
  @@map("production_entries")
}

// ──────────────────── M3 — Finance & Cost ────────────────────

model BudgetLine {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  category       CostCategory @default(OTHER)
  description    String
  amount         Decimal      @default(0) @db.Decimal(18, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("budget_lines")
}

model CostEntry {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  category       CostCategory @default(OTHER)
  description    String
  amount         Decimal      @default(0) @db.Decimal(18, 2)
  date           DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, date])
  @@map("cost_entries")
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String
  number         String
  description    String?
  amount         Decimal       @default(0) @db.Decimal(18, 2)
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([organizationId])
  @@index([projectId])
  @@map("invoices")
}

model Payment {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  invoiceId      String?
  reference      String
  amount         Decimal  @default(0) @db.Decimal(18, 2)
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@map("payments")
}

// ──────────────────── M4 — Inventory ─────────────────────────

model Material {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  unit           String   @default("unit")
  reorderLevel   Decimal  @default(0) @db.Decimal(18, 3)
  unitCost       Decimal  @default(0) @db.Decimal(18, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("materials")
}

model StockMovement {
  id             String       @id @default(cuid())
  organizationId String
  materialId     String
  projectId      String?
  type           MovementType
  quantity       Decimal      @default(0) @db.Decimal(18, 3)
  unitCost       Decimal      @default(0) @db.Decimal(18, 2)
  reference      String?
  note           String?
  date           DateTime     @default(now())
  createdAt      DateTime     @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([materialId, date])
  @@map("stock_movements")
}

// ──────────────────── M17 — Procurement ──────────────────────

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  contactName    String?
  email          String?
  phone          String?
  rating         Float    @default(0)
  leadTimeDays   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
  @@map("suppliers")
}

model PurchaseOrder {
  id             String   @id @default(cuid())
  organizationId String
  supplierId     String
  projectId      String?
  number         String
  status         PoStatus @default(DRAFT)
  total          Decimal  @default(0) @db.Decimal(18, 2)
  orderDate      DateTime @default(now())
  expectedDate   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  project  Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]

  @@index([organizationId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  description     String
  unit            String  @default("unit")
  quantity        Decimal @default(0) @db.Decimal(18, 3)
  rate            Decimal @default(0) @db.Decimal(18, 2)
  amount          Decimal @default(0) @db.Decimal(18, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

// ──────────────────── M5 — QA / QC ───────────────────────────

model Inspection {
  id             String           @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  type           String           @default("General")
  result         InspectionResult @default(PENDING)
  inspector      String?
  date           DateTime         @default(now())
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("inspections")
}

model Ncr {
  id               String    @id @default(cuid())
  organizationId   String
  projectId        String
  number           String
  description      String
  severity         Severity  @default(MEDIUM)
  status           NcrStatus @default(OPEN)
  correctiveAction String?
  raisedBy         String?
  closedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, status])
  @@map("ncrs")
}

// ──────────────────── M6 — HSE ───────────────────────────────

model Incident {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  type           IncidentType @default(NEAR_MISS)
  severity       Severity     @default(LOW)
  description    String
  location       String?
  reportedBy     String?
  date           DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("incidents")
}

model ToolboxTalk {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  topic          String
  presenter      String?
  attendees      Int      @default(0)
  date           DateTime @default(now())
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("toolbox_talks")
}

// ──────────────────── M24 — Risk ─────────────────────────────

model Risk {
  id             String     @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  category       String     @default("General")
  probability    Int        @default(3) // 1-5
  impact         Int        @default(3) // 1-5
  score          Int        @default(9) // probability * impact
  status         RiskStatus @default(OPEN)
  mitigation     String?
  owner          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, status])
  @@map("risks")
}

// ──────────────────── M7 — Documents ─────────────────────────

model Document {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String?
  name           String
  category       String   @default("General")
  url            String
  version        Int      @default(1)
  uploadedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@map("documents")
}

// ──────────────────── M9 — Notifications ─────────────────────

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String?
  type           NotificationType @default(GENERAL)
  severity       Severity         @default(LOW)
  title          String
  message        String
  link           String?
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, isRead])
  @@index([userId])
  @@map("notifications")
}

// ──────────────────── M13 — Scheduling (CPM) ─────────────────

model ScheduleActivity {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  code           String
  name           String
  durationDays   Int      @default(1)
  // Predecessor activity codes (finish-to-start) within the same project.
  predecessors   String[]
  progressPct    Float    @default(0)
  startDate      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("schedule_activities")
}

// ──────────────────── M16 — Field Operations ─────────────────

model SiteDiary {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  date           DateTime @default(now())
  weather        String?
  workforce      Int      @default(0)
  notes          String
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, date])
  @@map("site_diaries")
}

model FieldTask {
  id             String     @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  description    String?
  assignee       String?
  status         TaskStatus @default(TODO)
  dueDate        DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, status])
  @@map("field_tasks")
}

model Attendance {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  date           DateTime @default(now())
  workerName     String
  trade          String?
  hoursWorked    Decimal  @default(0) @db.Decimal(8, 2)
  present        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, date])
  @@map("attendances")
}

// ──────────────────── M18 — Workflow / Approvals ─────────────

model ApprovalRequest {
  id             String         @id @default(cuid())
  organizationId String
  projectId      String?
  title          String
  entityType     String         @default("general")
  entityId       String?
  amount         Decimal        @default(0) @db.Decimal(18, 2)
  status         ApprovalStatus @default(PENDING)
  requestedById  String?
  decidedById    String?
  decisionNote   String?
  decidedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@map("approval_requests")
}
