// INSPECTA BUILDOS — Prisma schema
// Multi-tenant construction ERP. All business records are scoped by
// organizationId; project-level records also carry projectId for fast scoping.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the musl target is for the Alpine Docker image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  SYSTEM_ADMIN
  PROJECT_MANAGER
  SITE_ENGINEER
  QUANTITY_SURVEYOR
  STOREKEEPER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectHealth {
  OPTIMAL
  WARNING
  CRITICAL
}

enum ContractType {
  LUMP_SUM
  UNIT_PRICE
  COST_PLUS
  TIME_AND_MATERIAL
}

enum ContractStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
}

enum CostCategory {
  LABOR
  MATERIAL
  EQUIPMENT
  SUBCONTRACTOR
  OVERHEAD
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  REJECTED
}

enum MovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT
  TRANSFER
  RETURN
  WASTE
}

enum CashDirection {
  IN
  OUT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NcrStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  INVESTIGATING
  CORRECTIVE_ACTION
  CLOSED
}

enum InspectionResult {
  PASS
  FAIL
  PENDING
}

enum IncidentType {
  NEAR_MISS
  FIRST_AID
  MEDICAL
  LOST_TIME
  FATALITY
  PROPERTY_DAMAGE
}

enum RiskStatus {
  OPEN
  MITIGATING
  CLOSED
}

enum PoStatus {
  DRAFT
  ISSUED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum NotificationType {
  DELAY
  COST_OVERRUN
  LOW_STOCK
  SAFETY_INCIDENT
  NCR
  GENERAL
  APPROVAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ────────────────────────── Tenancy ──────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Company settings (managed by SYSTEM_ADMIN via /api/organization)
  legalName String?
  industry  String?
  country   String?
  timezone  String?
  currency  String?
  phone     String?
  address   String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  clients       Client[]
  projects      Project[]
  contracts     Contract[]
  auditLogs     AuditLog[]
  materials     Material[]
  suppliers     Supplier[]
  documents     Document[]
  notifications Notification[]

  @@map("organizations")
}

// ──────────────────────────── Users ──────────────────────────

model User {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  passwordHash   String
  fullName       String
  role           Role      @default(SITE_ENGINEER)
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens   RefreshToken[]
  managedProjects Project[]      @relation("ProjectManager")
  auditLogs       AuditLog[]
  notifications   Notification[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────── Clients & Contracts ─────────────────

model Client {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  taxNumber      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]
  contracts    Contract[]

  @@index([organizationId])
  @@map("clients")
}

model Contract {
  id             String         @id @default(cuid())
  organizationId String
  clientId       String
  projectId      String?        @unique
  reference      String
  contractNumber String?
  type           ContractType   @default(LUMP_SUM)
  status         ContractStatus @default(DRAFT)
  value          Decimal        @default(0) @db.Decimal(18, 2)
  currency       String         @default("USD")
  startDate      DateTime?
  endDate        DateTime?
  contractDate         DateTime?
  commencementDate     DateTime?
  defectsLiabilityDays Int?
  retentionPct         Decimal?  @db.Decimal(5, 2)
  advancePayment       Decimal?  @db.Decimal(18, 2)
  documentsUrl         String?
  // Lifecycle / audit columns (multi-tenant spec)
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("contracts")
}

// ─────────────────────────── Projects ────────────────────────

model Project {
  id             String        @id @default(cuid())
  organizationId String
  clientId       String?
  managerId      String?
  code           String
  name           String
  description    String?
  location       String?
  projectType         String?
  category            String?
  timezone            String?
  gpsLat              Float?
  gpsLng              Float?
  plannedProfitMargin Decimal?      @db.Decimal(5, 2)
  status         ProjectStatus @default(PLANNING)
  health         ProjectHealth @default(OPTIMAL)
  budget         Decimal       @default(0) @db.Decimal(18, 2)
  currency       String        @default("USD")
  progressPct    Float         @default(0)
  startDate      DateTime?
  endDate        DateTime?
  actualEndDate  DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  manager      User?        @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)
  contract     Contract?

  wbsItems         WbsItem[]
  boqItems         BoqItem[]
  productionEntries ProductionEntry[]
  dailyReports      DailyReport[]
  budgetLines      BudgetLine[]
  costEntries      CostEntry[]
  invoices         Invoice[]
  payments         Payment[]
  stockMovements   StockMovement[]
  purchaseOrders   PurchaseOrder[]
  inspections      Inspection[]
  ncrs             Ncr[]
  incidents        Incident[]
  toolboxTalks      ToolboxTalk[]
  risks             Risk[]
  documents         Document[]
  scheduleActivities ScheduleActivity[]
  siteDiaries        SiteDiary[]
  fieldTasks         FieldTask[]
  attendances        Attendance[]
  approvalRequests   ApprovalRequest[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([clientId])
  @@map("projects")
}

// ───────────────────────── Audit trail ───────────────────────

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  userId         String?
  action         AuditAction
  entity         String
  entityId       String?
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, entity])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ──────────────────── M1 — Planning: WBS / BOQ ───────────────

model WbsItem {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  parentId       String?
  code           String
  name           String
  description    String?
  unit           String?
  quantity       Decimal? @db.Decimal(18, 3)
  level          Int      @default(1)
  weightPct      Float    @default(0)
  progressPct    Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   WbsItem?  @relation("WbsTree", fields: [parentId], references: [id], onDelete: SetNull)
  children WbsItem[] @relation("WbsTree")
  boqItems BoqItem[]

  @@index([organizationId])
  @@index([projectId])
  @@map("wbs_items")
}

model BoqItem {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  wbsItemId      String?
  code           String
  category       String?
  description    String
  unit           String   @default("unit")
  quantity       Decimal  @default(0) @db.Decimal(18, 3)
  rate           Decimal  @default(0) @db.Decimal(18, 2)
  amount         Decimal  @default(0) @db.Decimal(18, 2)
  markupPct      Decimal? @db.Decimal(5, 2)
  contingencyPct Decimal? @db.Decimal(5, 2)
  budget         Decimal  @default(0) @db.Decimal(18, 2)
  revision       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsItem WbsItem? @relation(fields: [wbsItemId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@map("boq_items")
}

// ──────────────────── M2 — Production Control ────────────────

model ProductionEntry {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  dailyReportId   String?
  date            DateTime @default(now())
  wbsActivity     String
  // Links to Module 1 entities (scalar FKs, joined in the analytics engine).
  wbsItemId             String?
  equipmentId           String?
  crewId                String?
  tradeId               String?
  productivityStandardId String?
  unit            String   @default("unit")
  plannedQty      Decimal  @default(0) @db.Decimal(18, 3)
  actualQty       Decimal  @default(0) @db.Decimal(18, 3)
  remainingQty    Decimal? @db.Decimal(18, 3)
  laborHours      Decimal  @default(0) @db.Decimal(12, 2)
  equipmentHours  Decimal  @default(0) @db.Decimal(12, 2)
  weatherCondition String?
  issues          String?
  delays          String?
  remarks         String?
  photos          String[]
  attachments     String[]
  createdById     String?
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyReport DailyReport? @relation(fields: [dailyReportId], references: [id], onDelete: SetNull)
  materials   ProductionMaterial[]

  @@index([organizationId])
  @@index([projectId, date])
  @@map("production_entries")
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// Daily Production Report header (Submodule 1).
model DailyReport {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  reportNumber   String
  reportDate     DateTime     @default(now())
  shift          String?
  weather        String?
  temperature    Float?
  preparedById   String?
  approvedById   String?
  approvedAt     DateTime?
  status         ReportStatus @default(DRAFT)
  notes          String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entries ProductionEntry[]

  @@index([organizationId])
  @@index([projectId])
  @@map("daily_reports")
}

// Material consumption per production entry (Material Used vs Planned).
model ProductionMaterial {
  id                String  @id @default(cuid())
  organizationId    String
  productionEntryId String
  materialId        String
  plannedQty        Decimal @default(0) @db.Decimal(18, 3)
  qtyUsed           Decimal @default(0) @db.Decimal(18, 3)
  wasteQty          Decimal @default(0) @db.Decimal(18, 3)
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entry ProductionEntry @relation(fields: [productionEntryId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([productionEntryId])
  @@map("production_materials")
}

// ──────────────────── M3 — Finance & Cost ────────────────────

model BudgetLine {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  wbsItemId      String?
  category       CostCategory @default(OTHER)
  budgetType     String       @default("ORIGINAL") // ORIGINAL | REVISED | FORECAST | CONTINGENCY
  costCode       String?
  description    String
  amount         Decimal      @default(0) @db.Decimal(18, 2)
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("budget_lines")
}

model CostEntry {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  wbsItemId      String?
  category       CostCategory @default(OTHER)
  source         String       @default("MANUAL") // MANUAL | PRODUCTION
  sourceRef      String?
  description    String
  amount         Decimal      @default(0) @db.Decimal(18, 2)
  date           DateTime     @default(now())
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, date])
  @@map("cost_entries")
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String
  number         String
  description    String?
  amount         Decimal       @default(0) @db.Decimal(18, 2)
  status         InvoiceStatus @default(DRAFT)
  // IPC / Interim Payment Certificate fields
  isIpc             Boolean  @default(false)
  certificateNumber String?
  grossValuation    Decimal? @db.Decimal(18, 2)
  previousCertified Decimal? @db.Decimal(18, 2)
  retentionPct      Decimal? @db.Decimal(5, 2)
  retentionAmount   Decimal? @db.Decimal(18, 2)
  advanceDeduction  Decimal? @db.Decimal(18, 2)
  taxPct            Decimal? @db.Decimal(5, 2)
  netAmount         Decimal? @db.Decimal(18, 2)
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([organizationId])
  @@index([projectId])
  @@map("invoices")
}

model Payment {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  invoiceId      String?
  reference      String
  amount         Decimal  @default(0) @db.Decimal(18, 2)
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@map("payments")
}

// ──────────────────── M4 — Inventory ─────────────────────────

model Material {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  category       String?
  supplierId     String?
  unit           String   @default("unit")
  reorderLevel   Decimal  @default(0) @db.Decimal(18, 3)
  unitCost       Decimal  @default(0) @db.Decimal(18, 2)
  standardCost   Decimal? @db.Decimal(18, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
  requirements   MaterialRequirement[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("materials")
}

model StockMovement {
  id             String       @id @default(cuid())
  organizationId String
  materialId     String
  projectId      String?
  type           MovementType
  quantity       Decimal      @default(0) @db.Decimal(18, 3)
  unitCost       Decimal      @default(0) @db.Decimal(18, 2)
  reference      String?
  warehouse      String?
  requestedBy    String?
  approvedBy     String?
  note           String?
  date           DateTime     @default(now())
  createdAt      DateTime     @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([materialId, date])
  @@map("stock_movements")
}

// ──────────────────── M17 — Procurement ──────────────────────

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  contactName    String?
  email          String?
  phone          String?
  rating         Float    @default(0)
  leadTimeDays   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
  @@map("suppliers")
}

model PurchaseOrder {
  id             String   @id @default(cuid())
  organizationId String
  supplierId     String
  projectId      String?
  number         String
  status         PoStatus @default(DRAFT)
  total          Decimal  @default(0) @db.Decimal(18, 2)
  orderDate      DateTime @default(now())
  expectedDate   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  project  Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]
  deliveries Delivery[]

  @@index([organizationId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  description     String
  unit            String  @default("unit")
  quantity        Decimal @default(0) @db.Decimal(18, 3)
  rate            Decimal @default(0) @db.Decimal(18, 2)
  amount          Decimal @default(0) @db.Decimal(18, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

// ──────────────────── M5 — QA / QC ───────────────────────────

model Inspection {
  id             String           @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  type           String           @default("General")
  wbsItemId      String?
  result         InspectionResult @default(PENDING)
  defects        Int              @default(0)
  inspector      String?
  date           DateTime         @default(now())
  photos         String[]
  attachments    String[]
  notes          String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("inspections")
}

model Ncr {
  id               String    @id @default(cuid())
  organizationId   String
  projectId        String
  number           String
  description      String
  wbsItemId        String?
  severity         Severity  @default(MEDIUM)
  status           NcrStatus @default(OPEN)
  rootCause        String?
  correctiveAction String?
  responsiblePerson String?
  dueDate          DateTime?
  photos           String[]
  attachments      String[]
  raisedBy         String?
  closedAt         DateTime?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actions CorrectiveAction[]

  @@index([organizationId])
  @@index([projectId, status])
  @@map("ncrs")
}

// ──────────────────── M6 — HSE ───────────────────────────────

model Incident {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String
  type           IncidentType @default(NEAR_MISS)
  severity       Severity     @default(LOW)
  description    String
  location       String?
  hazard         String?
  investigation  String?
  rootCause      String?
  correctiveAction String?
  reportedBy     String?
  date           DateTime     @default(now())
  photos         String[]
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("incidents")
}

model ToolboxTalk {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  topic          String
  presenter      String?
  attendees      Int      @default(0)
  date           DateTime @default(now())
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("toolbox_talks")
}

// ──────────────────── M24 — Risk ─────────────────────────────

model Risk {
  id             String     @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  category       String     @default("General")
  probability    Int        @default(3) // 1-5
  impact         Int        @default(3) // 1-5
  score          Int        @default(9) // probability * impact
  status         RiskStatus @default(OPEN)
  mitigation     String?
  owner          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, status])
  @@map("risks")
}

// ──────────────────── M7 — Documents ─────────────────────────

model Document {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String?
  name           String
  category       String   @default("General")
  url            String
  version        Int      @default(1)
  uploadedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@map("documents")
}

// ──────────────────── M9 — Notifications ─────────────────────

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String?
  type           NotificationType @default(GENERAL)
  severity       Severity         @default(LOW)
  title          String
  message        String
  link           String?
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, isRead])
  @@index([userId])
  @@map("notifications")
}

// ──────────────────── M13 — Scheduling (CPM) ─────────────────

enum DependencyType {
  FS // Finish-to-Start
  SS // Start-to-Start
  FF // Finish-to-Finish
  SF // Start-to-Finish
}

model ScheduleActivity {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  code           String
  name           String
  durationDays   Int      @default(1)
  // Legacy finish-to-start predecessor codes; typed links live in ScheduleDependency.
  predecessors   String[]
  progressPct    Float    @default(0)
  startDate      DateTime?
  finishDate     DateTime?
  milestone      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dependencies ScheduleDependency[] @relation("ActivityDeps")
  dependents   ScheduleDependency[] @relation("PredecessorDeps")

  @@index([organizationId])
  @@index([projectId])
  @@map("schedule_activities")
}

// Typed schedule relationship (FS/SS/FF/SF) with optional lag, between two
// activities. `activity` depends on `predecessor`.
model ScheduleDependency {
  id             String         @id @default(cuid())
  organizationId String
  projectId      String
  activityId     String
  predecessorId  String
  type           DependencyType @default(FS)
  lagDays        Int            @default(0)
  createdBy      String?
  updatedBy      String?
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  activity    ScheduleActivity @relation("ActivityDeps", fields: [activityId], references: [id], onDelete: Cascade)
  predecessor ScheduleActivity @relation("PredecessorDeps", fields: [predecessorId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("schedule_dependencies")
}

// ──────────────────── M16 — Field Operations ─────────────────

model SiteDiary {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  date           DateTime @default(now())
  weather        String?
  workforce      Int      @default(0)
  notes          String
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, date])
  @@map("site_diaries")
}

model FieldTask {
  id             String     @id @default(cuid())
  organizationId String
  projectId      String
  title          String
  description    String?
  assignee       String?
  status         TaskStatus @default(TODO)
  dueDate        DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, status])
  @@map("field_tasks")
}

model Attendance {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  date           DateTime @default(now())
  workerName     String
  trade          String?
  hoursWorked    Decimal  @default(0) @db.Decimal(8, 2)
  present        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId, date])
  @@map("attendances")
}

// ──────────────────── M18 — Workflow / Approvals ─────────────

model ApprovalRequest {
  id             String         @id @default(cuid())
  organizationId String
  projectId      String?
  title          String
  entityType     String         @default("general")
  entityId       String?
  amount         Decimal        @default(0) @db.Decimal(18, 2)
  status         ApprovalStatus @default(PENDING)
  requestedById  String?
  decidedById    String?
  decisionNote   String?
  decidedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@map("approval_requests")
}

// ════════════════ MODULE 1 — Resource Planning ════════════════
// Productivity Standards (#5), Human Resource Planning (#6).
// organizationId is the tenant key (scalar, matching the leaf-model pattern).

// Productivity library: planned output rate per activity/unit.
model ProductivityStandard {
  id                  String   @id @default(cuid())
  organizationId      String
  activity            String
  unit                String
  productivityRate    Decimal  @db.Decimal(18, 4) // output units per crew-day
  benchmarkSource     String?
  companyStandard     Decimal? @db.Decimal(18, 4)
  historicalStandard  Decimal? @db.Decimal(18, 4)
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("productivity_standards")
}

// Trade / craft classification (e.g. Mason, Steel Fixer).
model Trade {
  id             String  @id @default(cuid())
  organizationId String
  code           String?
  name           String
  description    String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees  Employee[]
  wageRates  WageRate[]

  @@index([organizationId])
  @@map("trades")
}

// Employee register with skills matrix & certifications.
model Employee {
  id             String   @id @default(cuid())
  organizationId String
  employeeNo     String?
  fullName       String
  tradeId        String?
  phone          String?
  email          String?
  status         String   @default("ACTIVE")
  dailyWage      Decimal? @db.Decimal(18, 2)
  skills         String[]
  certifications String[]
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trade        Trade?             @relation(fields: [tradeId], references: [id], onDelete: SetNull)
  crewMembers  CrewMember[]
  availability LaborAvailability[]

  @@index([organizationId])
  @@map("employees")
}

// Wage rate by trade (hourly/daily), effective from a date.
model WageRate {
  id             String   @id @default(cuid())
  organizationId String
  tradeId        String
  rateType       String   @default("DAILY") // DAILY | HOURLY
  amount         Decimal  @db.Decimal(18, 2)
  currency       String   @default("USD")
  effectiveDate  DateTime?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("wage_rates")
}

// Crew = a named team, optionally tied to a project.
model Crew {
  id             String  @id @default(cuid())
  organizationId String
  projectId      String?
  name           String
  description    String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members CrewMember[]

  @@index([organizationId])
  @@map("crews")
}

model CrewMember {
  id             String  @id @default(cuid())
  organizationId String
  crewId         String
  employeeId     String
  roleInCrew     String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  crew     Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("crew_members")
}

// Labor availability calendar per employee.
model LaborAvailability {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String
  date           DateTime
  available      Boolean  @default(true)
  hoursAvailable Float?
  note           String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("labor_availability")
}

// ════════════════ MODULE 1 — Equipment Planning (#7) ════════════════

model EquipmentCategory {
  id             String  @id @default(cuid())
  organizationId String
  code           String?
  name           String
  description    String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipment Equipment[]

  @@index([organizationId])
  @@map("equipment_categories")
}

model Equipment {
  id              String   @id @default(cuid())
  organizationId  String
  code            String?
  name            String
  categoryId      String?
  ownershipStatus String   @default("OWNED") // OWNED | RENTED | LEASED
  status          String   @default("AVAILABLE") // AVAILABLE | IN_USE | MAINTENANCE
  hourlyRate      Decimal? @db.Decimal(18, 2)
  dailyRate       Decimal? @db.Decimal(18, 2)
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category    EquipmentCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  utilization EquipmentUtilization[]
  maintenance EquipmentMaintenance[]

  @@index([organizationId])
  @@map("equipment")
}

// Planned utilization: Utilization = Planned Hours / Available Hours.
model EquipmentUtilization {
  id             String   @id @default(cuid())
  organizationId String
  equipmentId    String
  projectId      String?
  periodStart    DateTime?
  plannedHours   Float    @default(0)
  availableHours Float    @default(0)
  utilizationPct Float    @default(0)
  note           String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("equipment_utilization")
}

model EquipmentMaintenance {
  id             String   @id @default(cuid())
  organizationId String
  equipmentId    String
  type           String?
  scheduledDate  DateTime?
  completedDate  DateTime?
  cost           Decimal? @db.Decimal(18, 2)
  status         String   @default("SCHEDULED") // SCHEDULED | DONE | OVERDUE
  notes          String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("equipment_maintenance")
}

// ════════════════ MODULE 1 — Material Planning (#8) ════════════════
// Planned material requirement per project (basis for MRP in procurement).
model MaterialRequirement {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String
  materialId      String
  plannedQuantity Decimal  @db.Decimal(18, 3)
  requiredByDate  DateTime?
  supplierId      String?
  leadTimeDays    Int?
  status          String   @default("PLANNED") // PLANNED | REQUESTED | ORDERED | FULFILLED
  note            String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@map("material_requirements")
}

// ════════════════ MODULE 1 — Procurement Planning (#9) ════════════════
// Workflow: DRAFT → SUBMITTED → APPROVED → ORDERED → DELIVERED → CLOSED
enum PrStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ORDERED
  DELIVERED
  CLOSED
}

model PurchaseRequest {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String?
  number         String
  title          String?
  status         PrStatus @default(DRAFT)
  neededByDate   DateTime?
  requestedById  String?
  approvedById   String?
  approvedAt     DateTime?
  decisionNote   String?
  total          Decimal  @default(0) @db.Decimal(18, 2)
  notes          String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PurchaseRequestItem[]

  @@index([organizationId])
  @@index([projectId])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                String  @id @default(cuid())
  purchaseRequestId String
  materialId        String?
  description       String
  unit              String  @default("unit")
  quantity          Decimal @default(0) @db.Decimal(18, 3)
  estimatedRate     Decimal @default(0) @db.Decimal(18, 2)
  amount            Decimal @default(0) @db.Decimal(18, 2)

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
  @@map("purchase_request_items")
}

// Request for Quotation + supplier quotes (vendor comparison).
model Rfq {
  id                String   @id @default(cuid())
  organizationId    String
  projectId         String?
  purchaseRequestId String?
  number            String
  status            String   @default("DRAFT") // DRAFT | SENT | AWARDED | CLOSED
  dueDate           DateTime?
  notes             String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes RfqQuote[]

  @@index([organizationId])
  @@map("rfqs")
}

model RfqQuote {
  id             String   @id @default(cuid())
  organizationId String
  rfqId          String
  supplierId     String
  totalAmount    Decimal  @default(0) @db.Decimal(18, 2)
  leadTimeDays   Int?
  awarded        Boolean  @default(false)
  notes          String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rfq Rfq @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("rfq_quotes")
}

// Delivery tracking (goods received against a PO).
model Delivery {
  id              String   @id @default(cuid())
  organizationId  String
  projectId       String?
  purchaseOrderId String?
  number          String
  status          String   @default("PENDING") // PENDING | PARTIAL | RECEIVED
  deliveryDate    DateTime?
  receivedBy      String?
  notes           String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("deliveries")
}

// ════════════════ MODULE 1 — BOQ Versioning (#3) ════════════════
// Point-in-time snapshot of a project's BOQ for revision history + cost comparison.
model BoqVersion {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  versionNo      Int
  label          String?
  note           String?
  totalCost      Decimal  @default(0) @db.Decimal(18, 2)
  totalBudget    Decimal  @default(0) @db.Decimal(18, 2)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items BoqVersionItem[]

  @@index([organizationId])
  @@index([projectId])
  @@map("boq_versions")
}

model BoqVersionItem {
  id             String   @id @default(cuid())
  boqVersionId   String
  code           String
  category       String?
  description    String
  unit           String   @default("unit")
  quantity       Decimal  @default(0) @db.Decimal(18, 3)
  rate           Decimal  @default(0) @db.Decimal(18, 2)
  amount         Decimal  @default(0) @db.Decimal(18, 2)
  markupPct      Decimal? @db.Decimal(5, 2)
  contingencyPct Decimal? @db.Decimal(5, 2)
  budget         Decimal  @default(0) @db.Decimal(18, 2)

  version BoqVersion @relation(fields: [boqVersionId], references: [id], onDelete: Cascade)

  @@index([boqVersionId])
  @@map("boq_version_items")
}

// ════════════════ MODULE 3 — Cash Flow Management ════════════════
// Manual cash movements (advances, retention release, overheads, etc.).
// Payments (inflows) and CostEntry (outflows) are also folded into the
// cash-flow engine; this captures items not represented elsewhere.
model CashFlowEntry {
  id             String        @id @default(cuid())
  organizationId String
  projectId      String?
  date           DateTime      @default(now())
  direction      CashDirection
  category       String // CLIENT_PAYMENT | ADVANCE | RETENTION_RELEASE | OTHER_INCOME | PAYROLL | SUPPLIER | EQUIPMENT | SUBCONTRACTOR | OVERHEAD | OTHER
  amount         Decimal       @default(0) @db.Decimal(18, 2)
  reference      String?
  note           String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@map("cash_flow_entries")
}

// ════════════════ MODULE 4 — Quality, Safety & Compliance ════════════════

// Material testing records (concrete/soil/asphalt/steel...).
model MaterialTest {
  id                String           @id @default(cuid())
  organizationId    String
  projectId         String
  materialId        String?
  supplierId        String?
  testType          String           @default("CONCRETE") // CONCRETE | SOIL | ASPHALT | STEEL | OTHER
  batchNumber       String?
  sampleDate        DateTime?
  resultDate        DateTime?
  result            InspectionResult @default(PENDING)
  labName           String?
  certificateNumber String?
  notes             String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@map("material_tests")
}

// First-class corrective actions (multiple per NCR).
model CorrectiveAction {
  id                String    @id @default(cuid())
  organizationId    String
  ncrId             String?
  projectId         String?
  description       String
  responsiblePerson String?
  dueDate           DateTime?
  status            String    @default("OPEN") // OPEN | IN_PROGRESS | VERIFIED | CLOSED
  verification      String?
  closedAt          DateTime?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ncr Ncr? @relation(fields: [ncrId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("corrective_actions")
}

// Rework management (integrates with cost + productivity).
model Rework {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  wbsItemId      String?
  ncrId          String?
  activity       String
  quantity       Decimal  @default(0) @db.Decimal(18, 3)
  laborCost      Decimal  @default(0) @db.Decimal(18, 2)
  equipmentCost  Decimal  @default(0) @db.Decimal(18, 2)
  reworkCost     Decimal  @default(0) @db.Decimal(18, 2)
  delayDays      Int      @default(0)
  status         String   @default("OPEN") // OPEN | IN_PROGRESS | DONE
  notes          String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@map("reworks")
}

// PPE issuance / tracking.
model PpeIssue {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String?
  employeeId     String?
  ppeType        String
  quantity       Int       @default(1)
  issueDate      DateTime?
  expiryDate     DateTime?
  notes          String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("ppe_issues")
}

// Safety inspections / audits (HSE-specific).
model SafetyInspection {
  id               String           @id @default(cuid())
  organizationId   String
  projectId        String
  title            String
  template         String?
  inspector        String?
  date             DateTime         @default(now())
  result           InspectionResult @default(PENDING)
  score            Float?
  findings         String?
  correctiveAction String?
  photos           String[]
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@map("safety_inspections")
}

// Compliance documents (method statements, ITPs, permits, certifications).
model ComplianceDocument {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String?
  docType        String    @default("METHOD_STATEMENT") // METHOD_STATEMENT | ITP | PERMIT | CERTIFICATION | REGULATORY
  title          String
  reference      String?
  version        String?
  status         String    @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | EXPIRED
  issueDate      DateTime?
  expiryDate     DateTime?
  fileUrl        String?
  notes          String?
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@map("compliance_documents")
}

// ════════════════ MODULE 5 — AI Copilot ════════════════
// Conversation memory (per user, org-scoped).
model AiConversation {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  title          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages AiMessage[]

  @@index([organizationId, userId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String // user | assistant
  content        String
  confidence     Int?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}
